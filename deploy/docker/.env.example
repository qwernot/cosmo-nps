# Server public IP or domain used in generated client configs.
PUBLIC_ADDR=YOUR_SERVER_IP

# Tunnel Control admin bootstrap. Only used when no enabled admin exists.
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# FRP ports.
FRP_BIND_PORT=17000
FRP_HTTP_PORT=9081
FRP_HTTPS_PORT=9444
FRP_DASHBOARD_PORT=0

# NPS ports.
NPS_WEB_PORT=0
NPS_BRIDGE_PORT=18024
NPS_TLS_BRIDGE_PORT=18025
NPS_HTTP_PORT=9080
NPS_HTTPS_PORT=9443

# Optional global user port range. With host networking, these ports are opened
# by frps/nps on demand, but your firewall/cloud security group must allow them.
USER_PORT_RANGE=10000-20000
