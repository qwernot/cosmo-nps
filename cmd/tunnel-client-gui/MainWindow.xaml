<Window x:Class="TunnelClientGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TunnelClientGui"
        mc:Ignorable="d"
        Title="Tunnel Client" Height="660" Width="980"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- ScrollBar sleek styling -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Margin="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border CornerRadius="4" Background="#3A4D8C" Opacity="0.4" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Input Styles -->
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#060814"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#253565"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#3B82F6"/>
                                <Setter Property="Background" TargetName="border" Value="#080C20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="Background" Value="#060814"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#253565"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type PasswordBox}">
                        <Border x:Name="border" CornerRadius="8" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter Property="BorderBrush" TargetName="border" Value="#3B82F6"/>
                                <Setter Property="Background" TargetName="border" Value="#080C20"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Radio Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="{x:Type RadioButton}">
            <Setter Property="GroupName" Value="NavGroup"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="border" CornerRadius="8" Margin="0,3" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" Padding="16,0">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#151D3A"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dynamic Action Button Styles -->
        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#F43F5E"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#E11D48"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#BE123C"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Background" TargetName="border" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" SnapsToDevicePixels="True" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#334155"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek ListView Header and Row Styling -->
        <Style TargetType="{x:Type ListView}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
        </Style>

        <Style TargetType="{x:Type ListViewItem}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#151E3D"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <GridViewRowPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#0F1630"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter Property="Background" TargetName="border" Value="#17224A"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type GridViewColumnHeader}">
            <Setter Property="Background" Value="#090E20"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="#151E3D"/>
            <Setter Property="Padding" Value="4,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridViewColumnHeader}">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="{x:Type CheckBox}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Grid Width="42" Height="20" VerticalAlignment="Center">
                                <Border x:Name="Track" CornerRadius="10" Background="#1E293B" BorderBrush="Transparent" BorderThickness="0" SnapsToDevicePixels="True"/>
                                <Border x:Name="Thumb" CornerRadius="8" Background="#64748B" Width="16" Height="16" HorizontalAlignment="Left" Margin="2,0" SnapsToDevicePixels="True"/>
                            </Grid>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter Property="Background" TargetName="Track" Value="#10B981"/>
                                <Setter Property="Background" TargetName="Thumb" Value="#FFFFFF"/>
                                <Setter Property="HorizontalAlignment" TargetName="Thumb" Value="Right"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Window Outer Border (Glow and shadow simulation) -->
    <Border CornerRadius="16" Background="#080A14" BorderThickness="1" BorderBrush="#1F2D5D">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.55" ShadowDepth="0" />
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <!-- Custom Title Bar -->
                <RowDefinition Height="50"/>
                <!-- Main Content Area -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="230"/>
                <!-- Content Area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Custom Drag Title Bar (Spans top of window) -->
            <Grid Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- Logo & Brand in Title Bar -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Border Width="28" Height="28" CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#06B6D4" Offset="0"/>
                                <GradientStop Color="#2563EB" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Path Data="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" Fill="White" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NPS 隧道客户端" Margin="10,0,0,0" Foreground="White" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right-side Window Control Buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
                    <Button Click="MinimizeButton_Click" Width="36" Height="30" Background="Transparent" BorderThickness="0" ToolTip="最小化">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="Transparent" CornerRadius="4">
                                    <Path Data="M19 13H5V11H19V13Z" Fill="#64748B" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" TargetName="btnBorder" Value="#1E293B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Click="CloseButton_Click" Width="36" Height="30" Background="Transparent" BorderThickness="0" Margin="4,0,0,0" ToolTip="关闭">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder" Background="Transparent" CornerRadius="4">
                                    <Path x:Name="btnClosePath" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41Z" Fill="#64748B" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" TargetName="btnBorder" Value="#E11D48"/>
                                        <Setter Property="Fill" TargetName="btnClosePath" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- LEFT SIDEBAR (Row 1, Column 0) -->
            <Border Grid.Row="1" Grid.Column="0" BorderBrush="#151E3D" BorderThickness="0,0,1,0" Background="#070912">
                <Grid Margin="16,10,16,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation Items -->
                    <StackPanel Grid.Row="0">
                        <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="True" Checked="NavButton_Checked" Tag="0">
                            <Grid Width="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3M9 17H7V15H9V17M9 13H7V11H9V13M9 9H7V7H9V9M17 17H11V15H17V17M17 13H11V11H17V13M17 9H11V7H17V9Z" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="连接状态" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}" Checked="NavButton_Checked" Tag="1">
                            <Grid Width="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3M9 17H7V15H9V17M9 13H7V11H9V13M9 9H7V7H9V9" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="运行日志" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton Style="{StaticResource NavButtonStyle}" Checked="NavButton_Checked" Tag="2">
                            <Grid Width="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="M19.14 12.94C19.18 12.63 19.2 12.32 19.2 12C19.2 11.68 19.18 11.37 19.14 11.06L21.17 9.47C21.35 9.32 21.4 9.07 21.29 8.87L19.37 5.54C19.25 5.34 19.01 5.27 18.8 5.35L16.41 6.31C15.91 5.93 15.37 5.61 14.79 5.38L14.43 2.84C14.39 2.62 14.2 2.45 13.97 2.45H10.1C9.88 2.45 9.69 2.62 9.65 2.84L9.29 5.38C8.71 5.61 8.17 5.93 7.67 6.31L5.28 5.35C5.07 5.27 4.83 5.34 4.71 5.54L2.79 8.87C2.68 9.07 2.73 9.32 2.91 9.47L4.94 11.06C4.9 11.37 4.88 11.68 4.88 12C4.88 12.32 4.9 12.63 4.94 12.94M12 15.6C10.01 15.6 8.4 13.99 8.4 12C8.4 10.01 10.01 8.4 12 8.4C13.99 8.4 15.6 10.01 15.6 12C15.6 13.99 13.99 15.6 12 15.6Z" Fill="{Binding RelativeSource={RelativeSource AncestorType=RadioButton}, Path=Foreground}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="系统设置" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </RadioButton>
                    </StackPanel>

                    <!-- Sidebar Status Panel -->
                    <Border Grid.Row="2" CornerRadius="12" Background="#0B0E20" BorderBrush="#1A244C" BorderThickness="1" Padding="14">
                        <StackPanel>
                            <!-- Connection Status Badge -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#F43F5E" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="未连接" Margin="8,0,0,0" Foreground="#64748B" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Metadata -->
                            <TextBlock Text="已启用隧道" Foreground="#64748B" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TunnelCountText" Text="0 个" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="运行时长" Foreground="#64748B" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="UptimeText" Text="-- : -- : --" Foreground="White" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                            <TextBlock Text="客户端用户" Foreground="#64748B" FontSize="11" Margin="0,0,0,2"/>
                            <TextBlock x:Name="ClientUserText" Text="未载入" Foreground="White" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT MAIN CONTENT (Row 1, Column 1) -->
            <Grid Grid.Row="1" Grid.Column="1" Margin="20,10,20,20">
                <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0" Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.Resources>

                    <!-- TAB 0: CONNECTION & TUNNELS -->
                    <TabItem>
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Form Card -->
                                <RowDefinition Height="Auto"/>
                                <!-- Active Tunnels List Card -->
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Form Card -->
                            <Border Grid.Row="0" CornerRadius="12" Background="#0D1226" BorderBrush="#1F2D5D" BorderThickness="1" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <TextBlock Grid.Row="0" Text="中心控制连接配置" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,16"/>

                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Labels -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器控制地址" Foreground="#94A3B8" FontSize="12" Margin="0,0,10,6"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="唯一用户名" Foreground="#94A3B8" FontSize="12" Margin="0,0,10,6"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="刷新间隔" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,6"/>

                                        <!-- Inputs -->
                                        <TextBox x:Name="ControlUrlBox" Grid.Row="1" Grid.Column="0" Text="http://127.0.0.1:8088" Margin="0,0,10,0"/>
                                        <TextBox x:Name="UsernameBox" Grid.Row="1" Grid.Column="1" Text="" Margin="0,0,10,0"/>
                                        <TextBox x:Name="RefreshBox" Grid.Row="1" Grid.Column="2" Text="30s"/>
                                    </Grid>

                                    <!-- Password and Actions -->
                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Vertical">
                                            <TextBlock Text="控制面板密码" Foreground="#94A3B8" FontSize="12" Margin="0,0,10,6"/>
                                            <PasswordBox x:Name="PasswordBox" Margin="0,0,10,0"/>
                                        </StackPanel>

                                        <Button x:Name="ConnectButton" Click="ConnectButton_Click" Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Content="开始连接" Height="40" Margin="0,18,10,0" VerticalAlignment="Bottom"/>
                                        <Button x:Name="DisconnectButton" Click="DisconnectButton_Click" Grid.Column="2" Style="{StaticResource DangerButtonStyle}" Content="断开连接" Height="40" Margin="0,18,0,0" VerticalAlignment="Bottom" IsEnabled="False"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Tunnels List Card -->
                            <Border Grid.Row="1" CornerRadius="12" Background="#0D1226" BorderBrush="#1F2D5D" BorderThickness="1" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="活动隧道映射" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                                    <ListView x:Name="TunnelsListView" Grid.Row="1" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="备注名称" Width="140" DisplayMemberBinding="{Binding Remark}"/>
                                                <GridViewColumn Header="隧道协议" Width="90">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1E293B" CornerRadius="4" Padding="6,2" BorderThickness="1" BorderBrush="#3B82F6">
                                                                <TextBlock Text="{Binding DisplayType}" Foreground="#60A5FA" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="本地地址" Width="130" DisplayMemberBinding="{Binding DisplayLocal}"/>
                                                <GridViewColumn Header="公网出口端口 / 域名映射" Width="200" DisplayMemberBinding="{Binding DisplayRemote}"/>
                                                <GridViewColumn Header="连接状态" Width="85">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="6" Height="6" Fill="#10B981" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                <TextBlock Text="{Binding DisplayStatus}" Foreground="#10B981" FontSize="12" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- TAB 1: SYSTEM LOGS -->
                    <TabItem>
                        <Border CornerRadius="12" Background="#0D1226" BorderBrush="#1F2D5D" BorderThickness="1" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <TextBlock Text="客户端运行日志" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <Button Click="ClearLogsButton_Click" Style="{StaticResource SecondaryButtonStyle}" Content="清空日志" Height="30" Padding="12,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="1" Background="#05070F" CornerRadius="8" BorderThickness="1" BorderBrush="#151E3D" Padding="15">
                                    <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="Transparent" Foreground="#CBD5E1" FontFamily="Consolas, JetBrains Mono, Courier New" FontSize="13"/>
                                </Border>
                            </Grid>
                        </Border>
                    </TabItem>

                    <!-- TAB 2: SYSTEM SETTINGS -->
                    <TabItem>
                        <Border CornerRadius="12" Background="#0D1226" BorderBrush="#1F2D5D" BorderThickness="1" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="系统参数配置" Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,20"/>

                                <StackPanel Grid.Row="1">
                                    <!-- Setting: Auto Start -->
                                    <Border BorderBrush="#151E3D" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="开机自动启动" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock Text="在 Windows 系统启动时，自动运行 NPS 隧道后台服务" Foreground="#64748B" FontSize="12"/>
                                            </StackPanel>
                                            <CheckBox x:Name="AutoStartToggle" Click="AutoStartToggle_Click" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Setting: Daemon Info -->
                                    <Border BorderBrush="#151E3D" BorderThickness="0,0,0,1" Padding="0,0,0,16" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="守护服务监听地址" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock Text="WPF 界面与 Go 守护进程通信的本地 HTTP API 地址" Foreground="#64748B" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock x:Name="DaemonAddressText" Grid.Column="1" Text="http://127.0.0.1:18090" Foreground="#3B82F6" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Setting: About -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="关于客户端" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <TextBlock Text="NPS Multi-Node Native Tunnel Client GUI 1.0.0" Foreground="#64748B" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="v1.0.0" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Border>
</Window>
